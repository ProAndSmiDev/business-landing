include _mixins
doctype html
html(lang="en")
    head
        meta(http-equiv="Content-Type" content="text/html; charset=UTF-8")
        +meta('viewport', 'width=device-width, initial-scale=1')
        block SEO
        each val, i in copyright
          +meta(i, val)
        +link('favicon.ico', 'shortcut icon')
        +link('styles', 'stylesheet')
    body
        .business-landing
            header.bl-header.__header
              p some header components here
            main.bl-main.__main
              block Main
            footer.bl-footer.__footer
              p some footer components here

    +script('libs.min')
    +script('app.min')
