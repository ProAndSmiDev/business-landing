mixin genMeta(name, content)
    meta(name=name content=content)

mixin genLink(file, rel)
    if(rel === 'shortcut icon')
        link(href='/img/' + file, rel=rel)
    else if(rel === 'stylesheet')
        link(href='/css/' + file + '.css', rel=rel)

mixin genScript(file)
    script(src="/js/" + file + ".js")

mixin genIconMenu(menu, parent, target)
  ul(class=prefix + '-list ' + parent + '__list')
    for val in menu
      li.__item
        a.__link(href=val.url title=val.urlTitle target=target)
          span.__icon(class='bel-list__icon--' + val.postfix)


mixin genMainMenu(menu, parent, isNav = false)
  if isNav
    nav(class=prefix + '-menu ' + parent + '__menu')
      ul(class=prefix + '-list ' + parent + '__list')
        for val in menu
          li.__item
            a.__link(href=val.url title=val.urlTitle)
              span.__txt= val.title
  else
    ul(class=prefix + '-list ' + parent + '__list')
      for val in menu
        li.__item
          a.__link(href=val.url title=val.urlTitle)
            span.__txt= val.title

mixin genTitle(type, parent, text, isInvert = false)
  if type === 'main'
    h1(class=prefix + '-title ' + parent + '__title')
      span.__text= text
  else if type === 'sec'
    h2.--is-sec(class=prefix + '-title ' + parent + '__title')
      span.__text= text
  else if type === 'thd'
    h3.--is-thd(class=prefix + '-title ' + parent + '__title')
      span.text= text
  else
    h4.--is-other(class=prefix + '-title ' + parent + '__title')
      span.text= text
