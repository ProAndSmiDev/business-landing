mixin genMeta(name, content)
    meta(name=name content=content)

mixin genLink(file, rel)
    if(rel === 'shortcut icon')
        link(href='/img/' + file, rel=rel)
    else if(rel === 'stylesheet')
        link(href='/css/' + file + '.css', rel=rel)

mixin genScript(file)
    script(src="/js/" + file + ".js")

mixin genIconMenu(menu, parent, target)
  ul(class=prefix + '-list ' + parent + '__list')
    for val in menu
      li(class=prefix + '-list__item')
        a(href=val.url title=val.urlTitle target=target class=prefix + '-list__link')
          span(class=prefix + '-list__icon ' + prefix + '-list__icon--' + val.postfix)


mixin genMainMenu(menu, parent, isNav = false)
  if isNav
    nav(class=prefix + '-menu ' + parent + '__menu')
      ul(class=prefix + '-menu-list ' + parent + '-menu__list')
        for val in menu
          li(class=prefix + '-menu-list__item')
            a(href=val.url title=val.urlTitle class=prefix + '-menu-list__link')
              span(class=prefix + '-menu-list__text')= val.title
  else
    ul(class=prefix + '-menu-list ' + parent + '__list')
      for val in menu
        li(class=prefix + '-menu-list__item')
          a(href=val.url title=val.urlTitle class=prefix + '-menu-list__link')
            span(class=prefix + '-menu-list__text')= val.title

mixin genTitle(type, parent, text, isInvert = false)
  if type === 'main'
    h1(class=prefix + '-title ' + parent + '__title')
      span(class=prefix + '-title__text')= text
  else if type === 'sec'
    h2(class=prefix + '-title ' + parent + '__title ' + parent + '__title--is-sec')
      span(class=prefix + '-title__text')= text
  else if type === 'thd'
    h3(class=prefix + '-title ' + parent + '__title ' + parent + '__title--is-thd')
      span(class=prefix + '-title__text')= text
  else
    h4(class=prefix + '-title ' + parent + '__title ' + parent + '__title--is-other')
      span(class=prefix + '-title__text')= text
